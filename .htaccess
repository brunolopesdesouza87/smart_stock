RewriteEngine On
RewriteBase /smart_stock/

# Sempre servir o build de produção
DirectoryIndex dist/index.html

# Assets gerados pelo Vite
RewriteRule ^assets/(.*)$ dist/assets/$1 [L,NC]

# Permite acesso direto a arquivos existentes
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Fallback para rotas SPA -> dist/index.html
RewriteRule ^$ dist/index.html [L]
RewriteRule . dist/index.html [L]
